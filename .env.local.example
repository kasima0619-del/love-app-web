# AI秘書「ねね」用 AIプロバイダー設定
# このファイルを .env.local にコピーして値を設定します（.env.local はgit管理対象外）
# 未設定の場合、AI秘書ねねは固定応答（モック）で動作します

# 使用するAIプロバイダー: openai（デフォルト）/ claude
AI_PROVIDER=openai

# --- OpenAI ---
# 取得方法: https://platform.openai.com/ でAPIキーを発行してください
OPENAI_API_KEY=

# 使用するOpenAIモデル（任意・未指定時は gpt-4o-mini）
OPENAI_MODEL=

# --- Claude（将来切替用） ---
# AI_PROVIDER=claude の場合に使用します
# 取得方法: https://console.anthropic.com/ でAPIキーを発行してください
ANTHROPIC_API_KEY=

# 使用するClaudeモデル（任意・未指定時は claude-sonnet-4-5-20250929）
ANTHROPIC_MODEL=

# --- LINE連携（Messaging API） ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Telegram連携（Bot API） ---
# 取得方法: Telegramで @BotFather に /newbot を送るとBotトークンが発行されます
TELEGRAM_BOT_TOKEN=
# Webhook検証用の任意の文字列（setWebhookのsecret_tokenと同じ値を設定）
TELEGRAM_WEBHOOK_SECRET=
